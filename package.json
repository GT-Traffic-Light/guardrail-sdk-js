{
  "name": "@guardrail-ai/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for AI Traffic Light for Code — security scanning API client",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "yarn build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "guardrail",
    "ai-traffic-light",
    "api",
    "sdk",
    "security",
    "code-review",
    "vulnerability-scanner",
    "sbom",
    "aivss",
    "cvss"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GT-Traffic-Light/guardrail-sdk-js"
  },
  "homepage": "https://code.aitrafficlight.com/docs",
  "bugs": {
    "url": "https://github.com/GT-Traffic-Light/guardrail-sdk-js/issues"
  }
}
